{
  "name": "rse-platform",
  "version": "1.0.0",
  "description": "Rwanda Stock Exchange - Broker to Buyer Platform",
  "private": true,
  "workspaces": ["apps/*", "libs/*"],
  "scripts": {
    "build:api": "cd apps/api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "start:api": "cd apps/api && npm run start:dev",
    "start:web": "cd apps/web && npm run start:dev",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "install:all": "npm install && cd apps/api && npm install && cd ../web && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
