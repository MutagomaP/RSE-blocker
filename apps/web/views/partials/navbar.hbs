<nav class="navbar">
  <div class="container navbar-inner">
    <a href="/" class="navbar-brand">
      <span class="brand-icon">RSE</span>
      <span class="brand-text">Rwanda Stock Exchange</span>
    </a>

    <ul class="navbar-nav">
      <li><a href="/market" class="nav-link {{#eq page 'market'}}active{{/eq}}">Market</a></li>
      <li><a href="/securities" class="nav-link {{#eq page 'securities'}}active{{/eq}}">Securities</a></li>
      <li><a href="/brokers" class="nav-link {{#eq page 'brokers'}}active{{/eq}}">Brokers</a></li>
      <li><a href="/how-it-works" class="nav-link">How It Works</a></li>
    </ul>

    <div class="navbar-actions">
      {{#if isLoggedIn}}
        <a href="/portfolio" class="nav-link {{#eq page 'portfolio'}}active{{/eq}}">Portfolio</a>
        <a href="/orders" class="btn btn-outline btn-sm">Trade</a>
        <div class="nav-user-menu">
          <button class="user-avatar-btn" onclick="toggleUserMenu()">
            <span class="avatar-initials">{{user.firstName.[0]}}{{user.lastName.[0]}}</span>
          </button>
          <div class="user-dropdown" id="userDropdown">
            <div class="dropdown-header">
              <p class="dropdown-name">{{user.firstName}} {{user.lastName}}</p>
              <p class="dropdown-role">{{upper user.role}}</p>
            </div>
            <a href="/dashboard" class="dropdown-item">Dashboard</a>
            <a href="/portfolio" class="dropdown-item">My Portfolio</a>
            <a href="/orders" class="dropdown-item">My Orders</a>
            <div class="dropdown-divider"></div>
            <a href="/auth/logout" class="dropdown-item dropdown-item-danger">Sign Out</a>
          </div>
        </div>
      {{else}}
        <a href="/auth/login" class="btn btn-ghost btn-sm">Log In</a>
        <a href="/auth/register" class="btn btn-primary btn-sm">Get Started</a>
      {{/if}}
    </div>

    <button class="mobile-menu-btn" onclick="toggleMobileMenu()" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
