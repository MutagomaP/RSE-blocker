<div style="min-height:100vh;background:var(--green-950);display:flex;align-items:center;justify-content:center;padding:2rem;">
  <div style="width:100%;max-width:500px;">
    <div style="text-align:center;margin-bottom:2rem;">
      <a href="/" style="display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem;">
        <span class="brand-icon" style="font-size:1rem;padding:6px 10px;">RSE</span>
        <span style="color:white;font-family:var(--font-heading);font-weight:600;">Rwanda Stock Exchange</span>
      </a>
      <h1 style="color:white;font-size:1.75rem;margin-bottom:0.5rem;">Create your account</h1>
      <p style="color:var(--green-300);">Start investing in Rwanda's capital markets</p>
    </div>

    {{#if error}}
    <div class="alert alert-danger">⚠ {{error}}</div>
    {{/if}}

    <div class="card">
      <div class="card-body" style="padding:2rem;">
        <form action="/auth/register" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">First Name</label>
              <input type="text" name="firstName" class="form-control" placeholder="Jean" required>
            </div>
            <div class="form-group">
              <label class="form-label">Last Name</label>
              <input type="text" name="lastName" class="form-control" placeholder="Mutabazi" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input type="tel" name="phone" class="form-control" placeholder="+250 788 000 000">
          </div>
          <div class="form-group">
            <label class="form-label">National ID</label>
            <input type="text" name="nationalId" class="form-control" placeholder="1199980012345678">
            <p class="form-hint">Required for KYC verification by CMA Rwanda</p>
          </div>
          <div class="form-group">
            <label class="form-label">Account Type</label>
            <select name="role" class="form-control">
              <option value="investor">Investor — Buy &amp; Sell Securities</option>
              <option value="broker">Broker — Execute Trades for Clients</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Minimum 8 characters" required minlength="8">
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-block" style="margin-top:0.5rem;">Create Account →</button>
          <p style="font-size:0.75rem;color:var(--neutral-400);text-align:center;margin-top:1rem;">
            By registering you agree to RSE Platform Terms &amp; CMA Rwanda regulations.
          </p>
        </form>
      </div>
    </div>

    <p style="text-align:center;color:var(--green-300);margin-top:1.5rem;font-size:0.9rem;">
      Already have an account? <a href="/auth/login" style="color:var(--gold-300);font-weight:600;">Sign in</a>
    </p>
  </div>
</div>
