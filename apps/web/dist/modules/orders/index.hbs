<section class="page-hero">
  <div class="container">
    <h1>Orders</h1>
    <p>
      {{#if isAdmin}}Admin view — all orders across all investors and brokers{{/if}}
      {{#if isBroker}}Broker view — orders routed through your firm{{/if}}
      {{#unless isAdminOrBroker}}Place buy/sell orders and track their execution{{/unless}}
    </p>
  </div>
</section>

<section class="section">
  <div class="container">

    {{#if success}}<div class="alert alert-success">✓ {{success}}</div>{{/if}}
    {{#if error}}<div class="alert alert-danger">⚠ {{error}}</div>{{/if}}

    <!-- ── INVESTOR: Place Order + My Orders ── -->
    {{#unless isAdminOrBroker}}
    <div style="display:grid;grid-template-columns:1fr 360px;gap:2rem;align-items:start;">

      <div>
        <div class="card">
          <div class="card-header">
            <h3>My Orders</h3>
            <span class="badge badge-secondary">{{myOrders.length}} total</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Security</th><th>Side</th><th>Type</th>
                  <th class="text-right">Qty</th><th class="text-right">Price</th>
                  <th class="text-right">Executed</th><th>Status</th><th>Date</th><th></th>
                </tr>
              </thead>
              <tbody>
                {{#each myOrders}}
                <tr>
                  <td><span class="ticker-badge">{{this.security.ticker}}</span></td>
                  <td><span class="badge {{badgeClass this.side}}">{{upper this.side}}</span></td>
                  <td class="text-sm text-muted">{{upper this.type}}</td>
                  <td class="text-right fw-600">{{this.quantity}}</td>
                  <td class="text-right text-sm">{{#if this.limitPrice}}{{formatCurrency this.limitPrice ''}}{{else}}Market{{/if}}</td>
                  <td class="text-right text-sm">{{#if this.executedPrice}}{{formatCurrency this.executedPrice ''}}{{else}}—{{/if}}</td>
                  <td><span class="badge {{badgeClass this.status}}">{{upper this.status}}</span></td>
                  <td class="text-xs text-muted">{{formatDate this.createdAt}}</td>
                  <td>
                    {{#eq this.status 'pending'}}
                    <form action="/orders/{{this.id}}/cancel" method="POST" style="display:inline;">
                      <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Cancel this order?')">Cancel</button>
                    </form>
                    {{/eq}}
                  </td>
                </tr>
                {{else}}
                <tr>
                  <td colspan="9" style="text-align:center;padding:3rem;">
                    <div style="color:var(--neutral-400);">
                      <div style="font-size:2rem;margin-bottom:0.5rem;">📋</div>
                      <p>No orders yet — place your first order using the form →</p>
                    </div>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Place Order Panel -->
      <div>
        <div class="trade-panel">
          <div class="trade-tabs">
            <button class="trade-tab buy active" onclick="switchOrderTab('buy')">Buy</button>
            <button class="trade-tab sell" onclick="switchOrderTab('sell')">Sell</button>
          </div>
          <div class="trade-body">
            <form action="/orders" method="POST">
              <input type="hidden" name="side" id="orderSide" value="buy">
              <div class="form-group">
                <label class="form-label">Security</label>
                <select name="securityId" id="securitySelect" class="form-control" required>
                  <option value="">Select a security…</option>
                </select>
                <p class="form-hint" id="currentPriceHint"></p>
              </div>
              <div class="form-group">
                <label class="form-label">Order Type</label>
                <select name="type" id="orderType" class="form-control">
                  <option value="market">Market Order — executes immediately</option>
                  <option value="limit">Limit Order — set your target price</option>
                </select>
              </div>
              <div class="form-group" id="limitPriceRow" style="display:none;">
                <label class="form-label">Limit Price (RWF)</label>
                <input type="number" name="limitPrice" class="form-control" step="0.0001" min="0.0001">
              </div>
              <div class="form-group">
                <label class="form-label">Quantity (Shares)</label>
                <input type="number" name="quantity" class="form-control" min="1" placeholder="e.g. 100" required>
              </div>
              <div class="form-group">
                <label class="form-label">Notes (optional)</label>
                <input type="text" name="notes" class="form-control" placeholder="Reference or instructions">
              </div>
              <button type="submit" id="orderSubmitBtn" class="btn btn-green btn-lg btn-block">Place Buy Order</button>
              <p style="font-size:0.72rem;color:var(--neutral-400);text-align:center;margin-top:0.75rem;">
                Market orders match immediately · Limit orders queue · T+2 settlement · ~1% commission
              </p>
            </form>
          </div>
        </div>
      </div>

    </div>
    {{/unless}}

    <!-- ── ADMIN / BROKER: All Orders Table ── -->
    {{#if isAdminOrBroker}}

    <!-- Filter bar -->
    <div class="card mb-3" style="padding:1.25rem 1.5rem;">
      <form action="/orders" method="GET" style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;">
        <div class="form-group" style="margin:0;">
          <label class="form-label">Status</label>
          <select name="status" class="form-control">
            <option value="">All Statuses</option>
            <option value="pending" {{#eq status 'pending'}}selected{{/eq}}>Pending</option>
            <option value="filled" {{#eq status 'filled'}}selected{{/eq}}>Filled</option>
            <option value="cancelled" {{#eq status 'cancelled'}}selected{{/eq}}>Cancelled</option>
            <option value="rejected" {{#eq status 'rejected'}}selected{{/eq}}>Rejected</option>
          </select>
        </div>
        <div class="form-group" style="margin:0;">
          <label class="form-label">Side</label>
          <select name="side" class="form-control">
            <option value="">Buy &amp; Sell</option>
            <option value="buy" {{#eq side 'buy'}}selected{{/eq}}>Buy only</option>
            <option value="sell" {{#eq side 'sell'}}selected{{/eq}}>Sell only</option>
          </select>
        </div>
        <button type="submit" class="btn btn-green">Filter</button>
        <a href="/orders" class="btn btn-secondary">Clear</a>
        <div style="margin-left:auto;display:flex;align-items:center;gap:0.5rem;">
          <span class="badge badge-secondary">{{allOrders.length}} orders shown</span>
          {{#if isAdmin}}<span class="badge badge-info">ADMIN VIEW</span>{{/if}}
          {{#if isBroker}}<span class="badge badge-warning">BROKER VIEW</span>{{/if}}
        </div>
      </form>
    </div>

    <!-- Stats row -->
    <div class="grid-4 mb-3">
      <div class="stat-card">
        <div class="stat-label">Total Orders</div>
        <div class="stat-value">{{allOrders.length}}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Pending</div>
        <div class="stat-value" style="color:var(--gold-500);">
          {{#each allOrders}}{{#eq this.status 'pending'}}•{{/eq}}{{/each}}
        </div>
        <div class="stat-label" style="margin-top:0.25rem;">
          {{#each allOrders}}{{#eq this.status 'pending'}}1{{/eq}}{{/each}}
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Buy Orders</div>
        <div class="stat-value positive">
          {{#each allOrders}}{{#eq this.side 'buy'}}•{{/eq}}{{/each}}
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Sell Orders</div>
        <div class="stat-value negative">
          {{#each allOrders}}{{#eq this.side 'sell'}}•{{/eq}}{{/each}}
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3>
          {{#if isAdmin}}All Platform Orders{{/if}}
          {{#if isBroker}}Orders via Your Firm{{/if}}
        </h3>
        <a href="/orders" class="btn btn-secondary btn-sm">Refresh</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Investor</th><th>Security</th><th>Side</th><th>Type</th>
              <th class="text-right">Qty</th><th class="text-right">Limit Price</th>
              <th class="text-right">Executed Price</th><th>Broker</th>
              <th>Status</th><th>Date</th>
            </tr>
          </thead>
          <tbody>
            {{#each allOrders}}
            <tr>
              <td>
                <div class="fw-600 text-sm">{{this.investor.firstName}} {{this.investor.lastName}}</div>
                <div class="text-xs text-muted">{{this.investor.email}}</div>
              </td>
              <td><span class="ticker-badge">{{this.security.ticker}}</span></td>
              <td><span class="badge {{badgeClass this.side}}">{{upper this.side}}</span></td>
              <td class="text-sm text-muted">{{upper this.type}}</td>
              <td class="text-right fw-600">{{this.quantity}}</td>
              <td class="text-right text-sm">{{#if this.limitPrice}}{{formatCurrency this.limitPrice ''}}{{else}}Market{{/if}}</td>
              <td class="text-right text-sm {{#if this.executedPrice}}fw-600{{/if}}">
                {{#if this.executedPrice}}{{formatCurrency this.executedPrice ''}}{{else}}—{{/if}}
              </td>
              <td class="text-xs text-muted">
                {{#if this.broker}}{{this.broker.firmName}}{{else}}Direct{{/if}}
              </td>
              <td><span class="badge {{badgeClass this.status}}">{{upper this.status}}</span></td>
              <td class="text-xs text-muted">{{formatDate this.createdAt}}</td>
            </tr>
            {{else}}
            <tr>
              <td colspan="10" style="text-align:center;padding:3rem;color:var(--neutral-400);">
                <div style="font-size:2rem;margin-bottom:0.5rem;">📭</div>
                <p>No orders found{{#if status}} with status "{{status}}"{{/if}}</p>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Admin/Broker also sees their own orders below -->
    {{#if myOrders.length}}
    <div class="card mt-4">
      <div class="card-header">
        <h3>My Personal Orders</h3>
        <span class="badge badge-secondary">{{myOrders.length}}</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Security</th><th>Side</th><th class="text-right">Qty</th>
              <th class="text-right">Price</th><th>Status</th><th>Date</th><th></th>
            </tr>
          </thead>
          <tbody>
            {{#each myOrders}}
            <tr>
              <td><span class="ticker-badge">{{this.security.ticker}}</span></td>
              <td><span class="badge {{badgeClass this.side}}">{{upper this.side}}</span></td>
              <td class="text-right fw-600">{{this.quantity}}</td>
              <td class="text-right text-sm">{{#if this.limitPrice}}{{formatCurrency this.limitPrice ''}}{{else}}Market{{/if}}</td>
              <td><span class="badge {{badgeClass this.status}}">{{upper this.status}}</span></td>
              <td class="text-xs text-muted">{{formatDate this.createdAt}}</td>
              <td>
                {{#eq this.status 'pending'}}
                <form action="/orders/{{this.id}}/cancel" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                </form>
                {{/eq}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
    {{/if}}

    {{/if}}

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const securitiesData = {{{securities}}};
    populateSecuritySelect(securitiesData);
  });
</script>
